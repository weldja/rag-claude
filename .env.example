# Copy this to .env and fill in your values
# docker-compose will pick this up automatically

# ── Database (defaults match docker-compose) ─────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=ragdb
DB_USER=rag
DB_PASSWORD=ragpass

# ── Claude API (required) ─────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model options:
#   claude-haiku-4-5-20251001   fastest & cheapest  (~$0.80/$4.00 per MTok)
#   claude-sonnet-4-6           balanced             (~$3.00/$15.00 per MTok)
#   claude-opus-4-6             highest quality      (~$15.00/$75.00 per MTok)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# LLM generation settings
MAX_TOKENS=1024
TEMPERATURE=0.1

# ── Embedding (local — no API cost) ──────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── RAG settings ─────────────────────────────────────────────────────
DOCS_PATH=docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVAL_K=4

# ── Performance ──────────────────────────────────────────────────────
BATCH_SIZE=100
MAX_WORKERS=4
CACHE_TTL=86400       # seconds; 0 to disable query caching
